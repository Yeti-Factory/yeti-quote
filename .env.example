# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file — it is in .gitignore.

# --- Public (client-visible, injected into the browser bundle) ---
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# --- Server-only (never exposed to the browser) ---
SUPABASE_PROJECT_ID=""
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

# Service role key — bypasses RLS. REQUIRED for server functions using
# supabaseAdmin (privileged admin/webhook operations). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=""

# Optional — set to "node-server" for self-hosted Node/Docker (Coolify),
# leave empty to keep the default Cloudflare Workers preset.
# NITRO_PRESET="node-server"
